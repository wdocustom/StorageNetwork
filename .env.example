# ============================================
# Environment Variables for Local Development
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ── Supabase ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (TEST MODE for local development) ──
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key

# Webhook secret from Stripe CLI (run: stripe listen --forward-to localhost:3000/api/webhooks/stripe)
# The CLI will output a webhook signing secret like: whsec_...
# Leave empty to skip signature verification during testing
STRIPE_WEBHOOK_SECRET=

# ── Resend (Email) ─────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
RESEND_SENDER_EMAIL=orders@yourdomain.com
RESEND_SENDER_NAME=Your App Name

# ── Google AI (Gemini) ────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Also used for Gemini TTS (voice Design Assistant)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# ── Replicate (AI Asset Forge — FLUX.1.1-pro image generation) ──
# Get from: https://replicate.com/account/api-tokens
# Each generated marketing asset costs the installer 1 credit
# (profiles.marketing_credits) and ~$0.04 of Replicate compute.
REPLICATE_API_TOKEN=r8_your_replicate_token

# ── OpenAI (optional — TTS fallback) ─────
# Only needed if Gemini TTS is unavailable. Voice Design Assistant
# falls back to OpenAI tts-1 "nova" voice for text-to-speech.
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key

# ── Upstash Redis (Rate Limiting + Caching) ──
# Get from: https://console.upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Cron Job Authentication ──────────────
# Generate a random secret: openssl rand -hex 32
# Used by Vercel cron jobs to authenticate with /api/cron/* endpoints.
CRON_SECRET=your-cron-secret

# ── Vercel Edge Config ────────────────────
# Auto-set when you link Edge Config in the Vercel dashboard.
# Used for dynamic cache control and pre-warming configuration.
# EDGE_CONFIG=https://edge-config.vercel.com/ecfg_...?token=...

# ── App Configuration ──────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Storage Network
NEXT_PUBLIC_APP_TAGLINE=Professional Storage Solutions
NEXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
